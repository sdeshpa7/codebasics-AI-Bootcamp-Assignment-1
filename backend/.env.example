# FinSolve RAG Pipeline — Environment Variables Template
# ───────────────────────────────────────────────────
# Rename this file to .env and fill in your actual keys.
# NEVER commit your actual .env file to version control.

# ── Groq (LLM) ──────────────────────────────
# Obtain your key from: https://console.groq.com/keys
GROQ_API_KEY=your_groq_api_key_here
GROQ_MODEL=openai/gpt-oss-20b

# ── Qdrant (Vector Database) ────────────────
# Set USE_LOCAL_QDRANT=True to use the local storage in data/qdrant_local
USE_LOCAL_QDRANT=True
QDRANT_URL=http://localhost:6333
QDRANT_API_KEY=

# ── Embedding Model ─────────────────────────
EMBEDDING_MODEL=all-MiniLM-L6-v2

# ── Collection Settings ─────────────────────
QDRANT_COLLECTION=finsolve_docs
